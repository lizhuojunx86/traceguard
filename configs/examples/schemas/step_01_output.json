{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Step 01 Collector Output",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "price": { "type": "number" },
          "volume": { "type": "number" }
        },
        "required": ["symbol", "price"]
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    }
  },
  "required": ["data", "timestamp", "source"]
}
