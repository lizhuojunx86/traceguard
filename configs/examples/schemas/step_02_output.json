{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Step 02 Analyzer Output",
  "type": "object",
  "properties": {
    "analysis": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": ["summary", "signals", "confidence"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "input_step": {
      "type": "string"
    }
  },
  "required": ["analysis", "timestamp", "input_step"]
}
