{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Step 04 Leads Report Output",
  "type": "object",
  "properties": {
    "report_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "markdown_path": { "type": "string" },
    "pdf_path": { "type": "string" },
    "lead_count": { "type": "integer", "minimum": 8 },
    "new_leads": { "type": "integer", "minimum": 0 },
    "repeat_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "telegram_sent": { "type": "boolean" }
  },
  "required": ["report_date", "markdown_path", "lead_count", "telegram_sent"]
}
